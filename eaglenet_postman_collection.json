{
  "info": {
    "name": "EagleNet Logistics API",
    "description": "Postman Collection for EagleNet Logistics API covering Shipments, Customs, Invoices, Payments, and Admin operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": "<YOUR_ACCESS_TOKEN>"
    },
    {
      "key": "shipmentId",
      "value": ""
    },
    {
      "key": "trackingNumber",
      "value": ""
    },
    {
      "key": "invoiceId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@eaglenet.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Shipments",
      "item": [
        {
          "name": "Create Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"air_freight\",\n    \"clientName\": \"Acme Corp\",\n    \"clientEmail\": \"logistics@acme.com\",\n    \"clientPhone\": \"+1234567890\",\n    \"originCountry\": \"USA\",\n    \"originCity\": \"New York\",\n    \"destinationCountry\": \"UK\",\n    \"destinationCity\": \"London\",\n    \"weightKg\": 500,\n    \"volumeCbm\": 2.5,\n    \"description\": \"Electronics\",\n    \"airlineOrVessel\": \"British Airways\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shipments",
              "host": ["{{baseUrl}}"],
              "path": ["shipments"]
            }
          }
        },
        {
          "name": "List Shipments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/shipments",
              "host": ["{{baseUrl}}"],
              "path": ["shipments"]
            }
          }
        },
        {
          "name": "Update Shipment Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"in_transit\",\n    \"note\": \"Departed from origin facility\",\n    \"triggerEmail\": true,\n    \"visibility\": \"public\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shipments/{{shipmentId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "{{shipmentId}}", "status"]
            }
          }
        },
        {
          "name": "Add Internal Note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"note\": \"Awaiting documents before clearance.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shipments/{{shipmentId}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "{{shipmentId}}", "notes"]
            }
          }
        },
        {
          "name": "Get Shipment Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/shipments/stats",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "stats"]
            }
          }
        },
        {
          "name": "Track Shipment (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/shipments/track/{{trackingNumber}}",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "track", "{{trackingNumber}}"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Customs Operations",
      "item": [
        {
          "name": "Update Customs Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"under_examination\",\n    \"remarks\": \"Inspecting cargo contents.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shipments/{{shipmentId}}/customs",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "{{shipmentId}}", "customs"]
            }
          }
        },
        {
          "name": "Get Customs Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/shipments/{{shipmentId}}/customs",
              "host": ["{{baseUrl}}"],
              "path": ["shipments", "{{shipmentId}}", "customs"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Financial & Invoicing",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"shipmentId\": \"{{shipmentId}}\",\n    \"items\": [\n        { \"description\": \"Air Freight Charges\", \"quantity\": 1, \"price\": 1500 },\n        { \"description\": \"Customs Handling\", \"quantity\": 1, \"price\": 250 }\n    ],\n    \"taxRate\": 7.5,\n    \"currency\": \"NGN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"]
            }
          }
        },
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["invoices"]
            }
          }
        },
        {
          "name": "Update Invoice Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"sent\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/invoices/{{invoiceId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["invoices", "{{invoiceId}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "5. Payments",
      "item": [
        {
          "name": "Initialize Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"shipmentId\": \"{{shipmentId}}\",\n    \"amount\": 1881.25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments/initialize",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "initialize"]
            }
          }
        },
        {
          "name": "List All Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["payments"]
            }
          }
        }
      ]
    }
  ]
}
