{
  "name": "eaglenet-api",
  "version": "1.0.0",
  "description": "Logistics company API",
  "main": "src/server.ts",
  "scripts": {
    "start": "node dist/src/server.js",
    "start:dev": "ts-node src/server.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d database/data-source.ts",
    "create:ceo": "ts-node src/controllers/create-ceo.ts",
    "seed:permissions": "ts-node src/scripts/seed-permissions.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@types/xlsx": "^0.0.35",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "file-type": "^16.5.4",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "nodemon": "^3.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.3.2",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
