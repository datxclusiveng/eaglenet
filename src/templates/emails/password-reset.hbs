{{!-- Password Reset Email — supports both link and code flows --}}
{{#> layout
  title="Password Reset Request"
  subject=subject
  preheader=preheader
  cta_text=cta_text
  cta_url=cta_url
  unsubscribe_message=unsubscribe_message
  year=year
  brandName=brandName
  brandUrl=brandUrl
  logoUrl=logoUrl
}}
  {{#if userName}}
    <p>Hello <strong>{{userName}}</strong>,</p>
  {{else}}
    <p>Hello,</p>
  {{/if}}

  <p>We received a request to reset the password for your <strong>{{brandName}}</strong> account.</p>

  {{#if resetCode}}
    <p>Use the verification code below to complete your password reset:</p>
    <div class="code-box">
      <span class="code-text">{{resetCode}}</span>
    </div>
    <p style="font-size:14px;color:#6b7280;">This code expires in <strong>15 minutes</strong>. If you did not request a password reset, please ignore this email — your account is secure.</p>

  {{else if cta_url}}
    <p>Click the button below to choose a new password. This link is valid for a limited time.</p>

    <div class="cta-container">
      <a href="{{cta_url}}" class="cta" target="_blank" rel="noopener noreferrer">{{#if cta_text}}{{cta_text}}{{else}}Reset Your Password{{/if}}</a>
    </div>

    <p style="font-size:14px;color:#6b7280;margin-top:24px;">If you did not request a password reset, you can safely ignore this email — your account remains secure.</p>
    <p style="font-size:14px;color:#6b7280;">If the button doesn't work, copy and paste this link into your browser:<br/><a href="{{cta_url}}" style="color:#3b2073;word-break:break-all;">{{cta_url}}</a></p>

  {{else}}
    <p>If you did not request a password reset, you can safely ignore this email.</p>
  {{/if}}
{{/layout}}
